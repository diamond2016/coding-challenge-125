{
  "name": "online-diff-viewer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm --filter frontend dev\" \"pnpm backend:dev\"",
    "backend:dev": "cd backend && . venv/bin/activate && uvicorn app.main:app --reload --port 8000",
    "frontend:dev": "cd frontend && pnpm vite"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
